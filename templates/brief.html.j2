<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ site_title }} — {{ today }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;700;800&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#1B2A4A;        /* 藍 */
    --paper:#FBFAF7;      /* 生成りの紙 */
    --kincha:#B07C1F;     /* 金茶(重要度マーカー) */
    --rule:#D8D4CA;       /* 罫線 */
    --muted:#6B7280;
    --serif:'Shippori Mincho',serif;
    --sans:'Noto Sans JP',sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:#EDEBE4;font-family:var(--sans);color:var(--ink);
       display:flex;flex-direction:column;align-items:center;padding:16px 12px 64px}

  /* ===== Brief カード(スクリーンショット対象) ===== */
  #brief-card{
    width:100%;max-width:560px;background:var(--paper);
    border-top:6px solid var(--ink);
    box-shadow:0 2px 16px rgba(27,42,74,.12);
    padding:28px 26px 24px;
  }
  .masthead{display:flex;justify-content:space-between;align-items:baseline;
    border-bottom:2px solid var(--ink);padding-bottom:10px}
  .masthead .brand{font-family:var(--serif);font-weight:800;font-size:1.05rem;letter-spacing:.06em}
  .masthead .date{font-size:.78rem;color:var(--muted);font-variant-numeric:tabular-nums}
  .one-line{font-family:var(--serif);font-weight:500;font-size:.92rem;
    padding:12px 0;border-bottom:1px solid var(--rule);color:var(--ink)}

  /* 一面トップ:大見出し明朝 */
  .top{padding:20px 0 18px;border-bottom:1px solid var(--rule)}
  .cat{display:inline-block;font-size:.68rem;font-weight:700;letter-spacing:.14em;
    color:var(--kincha);border:1px solid var(--kincha);padding:2px 8px;margin-bottom:10px}
  .top h1{font-family:var(--serif);font-weight:800;font-size:1.72rem;line-height:1.32;
    letter-spacing:.01em;margin-bottom:12px}
  .top .summary{font-size:.95rem;line-height:1.8;margin-bottom:8px}
  .why{font-size:.86rem;line-height:1.7;color:#3D4A66;
    border-left:3px solid var(--kincha);padding-left:10px}

  /* 続報:小さく整然と */
  .story{display:grid;grid-template-columns:auto 1fr;gap:12px;
    padding:14px 0;border-bottom:1px solid var(--rule)}
  .story .cat{margin:2px 0 0;font-size:.62rem;height:fit-content}
  .story h2{font-family:var(--serif);font-weight:700;font-size:1.02rem;line-height:1.45;margin-bottom:4px}
  .story p{font-size:.82rem;line-height:1.65;color:#3D4A66}
  .conf{font-size:.68rem;color:var(--muted);margin-left:6px}

  .card-foot{padding-top:14px;font-size:.7rem;color:var(--muted);
    display:flex;justify-content:space-between}

  /* ===== 深掘り(Level 2)===== */
  .deep-wrap{width:100%;max-width:560px;margin-top:28px}
  .deep-wrap>h3{font-family:var(--serif);font-size:1rem;font-weight:700;
    letter-spacing:.1em;margin-bottom:10px;color:var(--ink)}
  details{background:#fff;border:1px solid var(--rule);margin-bottom:10px}
  summary{cursor:pointer;padding:14px 16px;font-family:var(--serif);
    font-weight:700;font-size:.95rem;list-style:none;display:flex;gap:10px;align-items:baseline}
  summary::before{content:"＋";color:var(--kincha);font-weight:700;flex:none}
  details[open] summary::before{content:"−"}
  .deep-body{padding:0 16px 16px;font-size:.86rem;line-height:1.8}
  .deep-body h4{font-size:.75rem;letter-spacing:.12em;color:var(--kincha);margin:14px 0 4px}
  .deep-body .sources{margin-top:12px;font-size:.75rem}
  .deep-body .sources a{color:var(--ink);word-break:break-all}

  @media (prefers-reduced-motion: reduce){*{transition:none!important}}
</style>
</head>
<body>

<div id="brief-card">
  <div class="masthead">
    <span class="brand">{{ site_title }}</span>
    <span class="date">{{ today }} {{ weekday }} 朝刊</span>
  </div>
  <p class="one-line">{{ d.one_line_world }}</p>

  <article class="top">
    <span class="cat">{{ d.top_story.category }}</span>
    <h1>{{ d.top_story.headline }}</h1>
    <p class="summary">{{ d.top_story.summary }}</p>
    <p class="why">{{ d.top_story.why_it_matters }}</p>
  </article>

  {% for s in d.stories %}
  <article class="story">
    <span class="cat">{{ s.category }}</span>
    <div>
      <h2>{{ s.headline }}<span class="conf">確度:{{ s.confidence }}</span></h2>
      <p>{{ s.summary }}</p>
    </div>
  </article>
  {% endfor %}

  <div class="card-foot">
    <span>AIが収集・2ソース以上で照合済み</span>
    <span>編集: AI編集長</span>
  </div>
</div>

<section class="deep-wrap">
  <h3>深掘り解説</h3>
  {% for s in [d.top_story] + d.stories %}
  <details{% if loop.first %} open{% endif %}>
    <summary>{{ s.headline }}</summary>
    <div class="deep-body">
      <h4>背景</h4><p>{{ s.deep.background }}</p>
      <h4>今後の展望</h4><p>{{ s.deep.outlook }}</p>
      <h4>あなたへの影響</h4><p>{{ s.deep.impact_on_you }}</p>
      <div class="sources">
        <h4>ソース(確度:{{ s.confidence }})</h4>
        {% for src in s.sources %}
        <div>・<a href="{{ src.url }}" target="_blank" rel="noopener">{{ src.title }}</a></div>
        {% endfor %}
      </div>
    </div>
  </details>
  {% endfor %}
</section>

</body>
</html>
