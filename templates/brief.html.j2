<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ site_title }} — {{ today }}</title>
{% set icon_path = 'icon.svg' if in_root else '../icon.svg' %}
{% set atouch_path = 'apple-touch-icon.png' if in_root else '../apple-touch-icon.png' %}
<link rel="icon" type="image/svg+xml" href="{{ icon_path }}">
<link rel="apple-touch-icon" href="{{ atouch_path }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;700;800&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#1B2A4A;        /* 藍 */
    --paper:#FBFAF7;      /* 生成りの紙 */
    --kincha:#B07C1F;     /* 金茶(重要度マーカー) */
    --rule:#D8D4CA;       /* 罫線 */
    --muted:#6B7280;
    --serif:'Shippori Mincho',serif;
    --sans:'Noto Sans JP',sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:#EDEBE4;font-family:var(--sans);color:var(--ink);
       display:flex;flex-direction:column;align-items:center;padding:16px 12px 64px}

  /* ===== Brief カード(スクリーンショット対象) ===== */
  #brief-card{
    width:100%;max-width:560px;background:var(--paper);
    border-top:6px solid var(--ink);
    box-shadow:0 2px 16px rgba(27,42,74,.12);
    padding:28px 26px 24px;
  }
  .masthead{display:flex;justify-content:space-between;align-items:baseline;
    border-bottom:2px solid var(--ink);padding-bottom:10px}
  .masthead .brand{font-family:var(--serif);font-weight:800;font-size:1.05rem;letter-spacing:.06em}
  .masthead-right{display:flex;align-items:baseline;gap:8px}
  .masthead .date{font-size:.78rem;color:var(--muted);font-variant-numeric:tabular-nums}
  .copy-icon-btn{background:none;border:none;padding:0 1px;margin:0;
    cursor:pointer;font-size:.82rem;color:var(--muted);line-height:1;
    opacity:.55;transition:opacity .15s,color .15s;vertical-align:baseline}
  .copy-icon-btn:hover{opacity:1}
  .copy-icon-btn.copied{color:var(--kincha);opacity:1}
  .one-line{font-family:var(--serif);font-weight:500;font-size:.92rem;
    padding:12px 0;border-bottom:1px solid var(--rule);color:var(--ink)}

  /* 一面トップ:大見出し明朝 */
  .top{padding:20px 0 18px;border-bottom:1px solid var(--rule)}
  .cat{display:inline-block;font-size:.68rem;font-weight:700;letter-spacing:.14em;
    color:var(--kincha);border:1px solid var(--kincha);padding:2px 8px;margin-bottom:10px}
  .top h1{font-family:var(--serif);font-weight:800;font-size:1.72rem;line-height:1.32;
    letter-spacing:.01em;margin-bottom:12px}
  .top .summary{font-size:.95rem;line-height:1.8;margin-bottom:8px}
  .why{font-size:.86rem;line-height:1.7;color:#3D4A66;
    border-left:3px solid var(--kincha);padding-left:10px}

  /* 続報:小さく整然と */
  .story{display:grid;grid-template-columns:auto 1fr;gap:12px;
    padding:14px 0;border-bottom:1px solid var(--rule)}
  .story .cat{margin:2px 0 0;font-size:.62rem;height:fit-content}
  .story h2{font-family:var(--serif);font-weight:700;font-size:1.02rem;line-height:1.45;margin-bottom:4px}
  .story p{font-size:.82rem;line-height:1.65;color:#3D4A66}
  .conf{font-size:.68rem;color:var(--muted);margin-left:6px}

  .card-foot{padding-top:14px;font-size:.7rem;color:var(--muted);
    display:flex;justify-content:space-between}

  /* ===== 深掘り(Level 2)===== */
  .deep-wrap{width:100%;max-width:560px;margin-top:28px}
  .deep-wrap>h3{font-family:var(--serif);font-size:1rem;font-weight:700;
    letter-spacing:.1em;margin-bottom:10px;color:var(--ink)}
  details{background:#fff;border:1px solid var(--rule);margin-bottom:10px}
  summary{cursor:pointer;padding:14px 16px;font-family:var(--serif);
    font-weight:700;font-size:.95rem;list-style:none;display:flex;gap:10px;align-items:baseline}
  summary::before{content:"＋";color:var(--kincha);font-weight:700;flex:none}
  details[open] summary::before{content:"−"}
  .deep-body{padding:14px 16px 16px;font-size:.86rem;line-height:1.8}
  .deep-body h4{font-size:.75rem;letter-spacing:.12em;color:var(--kincha);margin:14px 0 4px}
  .deep-body .sources{margin-top:14px;font-size:.75rem}
  .deep-body .sources a{color:var(--ink);word-break:break-all}
  .art-copy-btn{background:none;border:1px solid var(--rule);border-radius:3px;
    padding:2px 8px;margin-top:14px;cursor:pointer;font-size:.72rem;
    color:var(--muted);display:block;margin-left:auto;
    transition:opacity .15s,color .15s,border-color .15s;opacity:.65}
  .art-copy-btn:hover{opacity:1;border-color:var(--kincha);color:var(--kincha)}
  .art-copy-btn.copied{color:var(--kincha);border-color:var(--kincha);opacity:1}

  /* ===== 図解A: キーメトリクス ===== */
  .metrics-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;}
  .metric-badge{
    flex:1;min-width:72px;
    background:#F5F3EE;border:1px solid var(--rule);
    border-top:3px solid var(--ink);padding:9px 10px;text-align:center;
  }
  .metric-value{
    display:block;font-family:var(--serif);font-size:1.55rem;font-weight:800;
    color:var(--ink);line-height:1.1;
  }
  .metric-label{
    display:block;font-size:.63rem;color:var(--muted);
    margin-top:4px;line-height:1.35;
  }

  /* ===== 図解A: タイムライン ===== */
  .tl-wrap{position:relative;padding-left:30px;margin:4px 0 14px;}
  .tl-wrap::before{
    content:'';position:absolute;left:9px;top:8px;bottom:10px;
    width:2px;background:var(--rule);
  }
  .tl-step{position:relative;margin-bottom:20px;}
  .tl-step:last-child{margin-bottom:0;}
  /* ドット: 装飾のみ・文字なし */
  .tl-dot{
    position:absolute;left:-25px;top:5px;
    width:10px;height:10px;border-radius:50%;
    background:#fff;border:2px solid #C0BBB0;
  }
  /* 色チップ: ブロック名のみここで示す */
  .tl-chip{
    display:inline-block;font-size:.63rem;font-weight:700;
    letter-spacing:.1em;color:#fff;padding:2px 9px;border-radius:2px;
    margin-bottom:6px;
  }
  .chip-bg {background:#5A6472;}
  .chip-out{background:#3E6B5E;}
  .chip-imp{background:#B07C1F;}
  /* キーメッセージ: 明朝体一文 */
  .tl-key{
    font-family:var(--serif);font-size:.9rem;font-weight:700;
    line-height:1.45;margin-bottom:5px;color:var(--ink);
  }
  .tl-body{font-size:.83rem;line-height:1.8;color:#3D4A66;}

  /* 対応策チェックリスト */
  .action-list{list-style:none;margin-top:9px;padding-left:0;}
  .action-list li{
    font-size:.82rem;line-height:1.7;
    padding-left:1.6em;position:relative;
  }
  .action-list li::before{
    content:'☑';position:absolute;left:0;color:var(--kincha);
  }

  /* ===== 図解A: 用語集 ===== */
  .glossary{
    margin-top:14px;border-top:1px solid var(--rule);padding-top:10px;
  }
  .glossary-hd{
    font-size:.68rem;letter-spacing:.14em;color:var(--kincha);
    font-weight:700;margin-bottom:7px;
  }
  .glossary-item{
    display:flex;gap:10px;font-size:.77rem;line-height:1.6;
    padding:5px 0;border-bottom:1px solid #EEEAE3;
  }
  .glossary-item:last-child{border-bottom:none;}
  .glossary-term{font-weight:700;color:var(--ink);flex:none;min-width:5.5em;}
  .glossary-desc{color:#3D4A66;}

  /* ===== アーカイブ(過去のBrief一覧)===== */
  .archive{width:100%;max-width:560px;margin-top:32px;
    border-top:2px solid var(--ink);padding-top:14px}
  .archive>h3{font-family:var(--serif);font-size:1rem;font-weight:700;
    letter-spacing:.1em;margin-bottom:10px;color:var(--ink)}
  .archive a{display:flex;gap:12px;align-items:baseline;text-decoration:none;
    color:var(--ink);padding:11px 4px;border-bottom:1px solid var(--rule)}
  .archive a:hover{background:#fff}
  .archive .a-date{font-variant-numeric:tabular-nums;font-weight:700;
    font-size:.82rem;color:var(--kincha);flex:none;width:5.2em}
  .archive .a-head{font-family:var(--serif);font-size:.86rem;line-height:1.5;
    overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

  @media (prefers-reduced-motion: reduce){*{transition:none!important}}
</style>
</head>
<body>

{% if not in_root %}
<div style="width:100%;max-width:560px;margin-bottom:10px">
  <a href="../" style="font-size:.8rem;color:#B07C1F;text-decoration:none">← 最新号・一覧へ</a>
</div>
{% endif %}

<div id="brief-card">
  <div class="masthead">
    <span class="brand">{{ site_title }}</span>
    <span class="masthead-right">
      <span class="date">{{ today }} {{ weekday }} 朝刊</span>
      <button id="copy-btn" class="copy-icon-btn" title="全文をMarkdownでコピー">📋</button>
    </span>
  </div>
  <p class="one-line">{{ d.one_line_world }}</p>

  <article class="top">
    <span class="cat">{{ d.top_story.category }}</span>
    <h1>{{ d.top_story.headline }}</h1>
    <p class="summary">{{ d.top_story.summary }}</p>
    <p class="why">{{ d.top_story.why_it_matters }}</p>
  </article>

  {% for s in d.stories %}
  <article class="story">
    <span class="cat">{{ s.category }}</span>
    <div>
      <h2>{{ s.headline }}<span class="conf">確度:{{ s.confidence }}</span></h2>
      <p>{{ s.summary }}</p>
    </div>
  </article>
  {% endfor %}

  <div class="card-foot">
    <span>AIが収集・2ソース以上で照合済み</span>
    <span>編集: AI編集長</span>
  </div>
</div>

<section class="deep-wrap">
  <h3>深掘り解説</h3>
  {% for s in [d.top_story] + d.stories %}
  <details{% if loop.first %} open{% endif %}>
    <summary>{{ s.headline }}</summary>
    <div class="deep-body">

      {# (1) キーメトリクス #}
      {% if s.key_metrics and s.key_metrics|length > 0 %}
      <div class="metrics-row">
        {% for m in s.key_metrics %}
        <div class="metric-badge">
          <span class="metric-value">{{ m.value }}</span>
          <span class="metric-label">{{ m.label }}</span>
        </div>
        {% endfor %}
      </div>
      {% endif %}

      {# (2) タイムライン: 背景・展望・影響 #}
      <div class="tl-wrap">

        <div class="tl-step">
          <div class="tl-dot"></div>
          <div>
            <span class="tl-chip chip-bg">背景</span>
            {% if s.deep.key_messages and s.deep.key_messages.background %}
            <p class="tl-key">{{ s.deep.key_messages.background }}</p>
            {% endif %}
            <p class="tl-body">{{ s.deep.background }}</p>
          </div>
        </div>

        <div class="tl-step">
          <div class="tl-dot"></div>
          <div>
            <span class="tl-chip chip-out">展望</span>
            {% if s.deep.key_messages and s.deep.key_messages.outlook %}
            <p class="tl-key">{{ s.deep.key_messages.outlook }}</p>
            {% endif %}
            <p class="tl-body">{{ s.deep.outlook }}</p>
          </div>
        </div>

        <div class="tl-step">
          <div class="tl-dot"></div>
          <div>
            <span class="tl-chip chip-imp">影響</span>
            {% if s.deep.key_messages and s.deep.key_messages.impact_on_you %}
            <p class="tl-key">{{ s.deep.key_messages.impact_on_you }}</p>
            {% endif %}
            <p class="tl-body">{{ s.deep.impact_on_you }}</p>
            {% if s.action_items and s.action_items|length > 0 %}
            <ul class="action-list">
              {% for item in s.action_items %}
              <li>{{ item }}</li>
              {% endfor %}
            </ul>
            {% endif %}
          </div>
        </div>

      </div>{# /tl-wrap #}

      {# (3) 用語集 #}
      {% if s.glossary and s.glossary|length > 0 %}
      <div class="glossary">
        <div class="glossary-hd">用語解説</div>
        {% for g in s.glossary %}
        <div class="glossary-item">
          <span class="glossary-term">{{ g.term }}</span>
          <span class="glossary-desc">{{ g.desc }}</span>
        </div>
        {% endfor %}
      </div>
      {% endif %}

      <div class="sources">
        <h4>ソース(確度:{{ s.confidence }})</h4>
        {% for src in s.sources %}
        <div>・<a href="{{ src.url }}" target="_blank" rel="noopener">{{ src.title }}</a></div>
        {% endfor %}
      </div>
      <button class="art-copy-btn" data-idx="{{ loop.index0 }}" title="この記事をMarkdownでコピー">📋 コピー</button>
    </div>
  </details>
  {% endfor %}
</section>

{% if in_root and archive|length > 1 %}
<section class="archive">
  <h3>過去のブリーフ</h3>
  {% for a in archive %}
  <a href="{{ a.date }}/">
    <span class="a-date">{{ a.label }}({{ a.weekday }})</span>
    <span class="a-head">{{ a.headline }}</span>
  </a>
  {% endfor %}
</section>
{% endif %}

<script type="application/json" id="briefData">
{{ {"today": today, "weekday": weekday, "title": site_title, "d": d}|tojson }}
</script>
<script>
(function(){
  var btn = document.getElementById('copy-btn');
  var data = JSON.parse(document.getElementById('briefData').textContent);

  function storyToMd(s){
    var lines = [];
    lines.push('## 《' + s.category + '》' + s.headline);
    lines.push('');
    lines.push(s.summary);
    lines.push('');
    if(s.why_it_matters){
      lines.push('**なぜ重要か:** ' + s.why_it_matters);
      lines.push('');
    }
    if(s.deep){
      lines.push('- **背景:** ' + s.deep.background);
      lines.push('- **今後の展望:** ' + s.deep.outlook);
      lines.push('- **あなたへの影響:** ' + s.deep.impact_on_you);
      lines.push('');
    }
    if(s.action_items && s.action_items.length){
      lines.push('**対応策:**');
      s.action_items.forEach(function(item){ lines.push('- ☑ ' + item); });
      lines.push('');
    }
    if(s.glossary && s.glossary.length){
      lines.push('**用語解説:**');
      s.glossary.forEach(function(g){ lines.push('- **' + g.term + '**: ' + g.desc); });
      lines.push('');
    }
    if(s.sources && s.sources.length){
      s.sources.forEach(function(src){
        lines.push('- [' + src.title + '](' + src.url + ')');
      });
      lines.push('');
    }
    return lines;
  }

  function buildMarkdown(){
    var d = data.d;
    var lines = [];
    lines.push('# ' + data.title + ' — ' + data.today + ' ' + data.weekday);
    lines.push('');
    lines.push('> ' + d.one_line_world);
    lines.push('');
    [d.top_story].concat(d.stories).forEach(function(s){
      storyToMd(s).forEach(function(l){ lines.push(l); });
    });
    return lines.join('\n');
  }

  function fallbackCopy(text, cb){
    var ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;top:0;left:0;width:1px;height:1px;opacity:0';
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    try{ document.execCommand('copy'); cb(); }catch(e){}
    document.body.removeChild(ta);
  }

  function doCopy(text, el, resetLabel){
    function onCopied(){
      el.textContent = '✓ コピー済み';
      el.classList.add('copied');
      setTimeout(function(){
        el.textContent = resetLabel;
        el.classList.remove('copied');
      }, 2000);
    }
    if(navigator.clipboard && navigator.clipboard.writeText){
      navigator.clipboard.writeText(text).then(onCopied).catch(function(){
        fallbackCopy(text, onCopied);
      });
    } else {
      fallbackCopy(text, onCopied);
    }
  }

  btn.addEventListener('click', function(){
    doCopy(buildMarkdown(), btn, '📋');
  });

  var allArticles = [data.d.top_story].concat(data.d.stories);
  document.querySelectorAll('.art-copy-btn').forEach(function(el){
    el.addEventListener('click', function(){
      var idx = parseInt(el.getAttribute('data-idx'), 10);
      var s = allArticles[idx];
      if(!s) return;
      doCopy(storyToMd(s).join('\n'), el, '📋 コピー');
    });
  });
})();
</script>
</body>
</html>
